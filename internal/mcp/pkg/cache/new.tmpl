package cache

import (
	"context"
	"crypto/tls"
	"fmt"
	"time"

	"github.com/noble-gase/ne/closekit"
	"github.com/noble-gase/ne/redkit"
	"github.com/redis/go-redis/v9"
	"github.com/redis/go-redis/v9/maintnotifications"
	"github.com/spf13/viper"
)

func New(cfgName string) redis.UniversalClient {
	var cfg redkit.Config
	if err := viper.UnmarshalKey(cfgName, &cfg); err != nil {
		panic(fmt.Errorf("Redis(%s) init failed: %w", cfgName, err))
	}

	client, err := redkit.NewClient(&cfg)
	if err != nil {
		return nil, err
	}

	closekit.Add(cfgName, closekit.P80, func() error {
		return client.Close()
	})

	return client
}
