package agent

import (
	"context"
	"fmt"
	"iter"
	"time"

	"{{.Module}}/pkg/cache"

	"github.com/achetronic/adk-utils-go/genai/openai"
	"github.com/modelcontextprotocol/go-sdk/mcp"
	"github.com/noble-gase/ne/helper"
	"github.com/noble-gase/ne/redlock"
	"github.com/spf13/viper"
	"google.golang.org/adk/agent"
	"google.golang.org/adk/agent/llmagent"
	"google.golang.org/adk/model"
	"google.golang.org/adk/runner"
	"google.golang.org/adk/session"
	"google.golang.org/adk/tool"
	"google.golang.org/adk/tool/mcptoolset"
	"google.golang.org/genai"
)

const MaxContextLen = 10

type Chat struct {
	runner  *runner.Runner
	session *Session
}

// Ask 问答
func (c *Chat) Ask(ctx context.Context, userId, text string) (iter.Seq2[*session.Event, error], error) {
	lockKey := fmt.Sprintf("mutex:agent_demo:session:%s", userId)
	lock := redlock.New(cache.R(), lockKey, time.Minute)
	if err := lock.TryAcquire(ctx, 60, time.Second); err != nil {
		return nil, err
	}
	defer lock.Release(ctx)

	sessionID, err := c.session.GetOrCreate(ctx, userId)
	if err != nil {
		return nil, err
	}

	return c.runner.Run(
		ctx,
		userId,
		sessionID,
		genai.NewContentFromText(text, genai.RoleUser),
		agent.RunConfig{
			StreamingMode: agent.StreamingModeSSE,
		},
	), nil
}

func (c *Chat) Close() error {
	fmt.Println("⌛️", "close chat ...")
	if c.session != nil {
		return c.session.Close()
	}
	return nil
}

type McpCfg struct {
	Endpoint string `mapstructure:"endpoint"`
}

type McpList struct {
	Mcp []McpCfg `mapstructure:"mcp"`
}

func NewChat(session *Session) (*Chat, error) {
	// MCP Toolset (Streamable HTTP)
	var mcpList McpList
	if err := viper.Unmarshal(&mcpList); err != nil {
		return nil, err
	}

	// Load MCP Toolsets
	toolsets := make([]tool.Toolset, 0, len(mcpList.Mcp))
	for _, c := range mcpList.Mcp {
		transport := &mcp.StreamableClientTransport{
			Endpoint:   c.Endpoint,
			HTTPClient: helper.NewHttpClient(),
		}
		toolset, err := mcptoolset.New(mcptoolset.Config{
			Transport: transport,
		})
		if err != nil {
			return nil, err
		}
		toolsets = append(toolsets, toolset)
	}

	// LLM Model (OpenAI compatible)
	llmModel := openai.New(openai.Config{
		APIKey:    viper.GetString("llm.apiKey"),
		BaseURL:   viper.GetString("llm.baseURL"),
		ModelName: viper.GetString("llm.model"),
	})

	// LLM Agent
	llmAgent, err := llmagent.New(llmagent.Config{
		Name:        session.AppName(),
		Model:       llmModel,
		Description: "IOTA智能助手",
		Instruction: `你是一个企业内部智能助手。
## 基本规则
- 用中文回答
- 回答简洁、准确，使用 Markdown 格式
- 如果用户问的问题与工具列表范围无关，请告知用户无法处理
- 遇到不确定的问题，请如实告知，并让用户找「盛辉」确认

## 时间处理
工具返回的时间戳统一按以下规则显示：
- 10位数字（秒时间戳），转换为 "YYYY-MM-DD HH:mm:ss" 格式
- 13位数字（毫秒时间戳），转换为 "YYYY-MM-DD HH:mm:ss.SSS" 格式
- 时区统一为 Asia/Shanghai

示例：
- 1773214741 -> 2026-03-11 17:39:01
- 1773214741567 -> 2026-03-11 17:39:01.567`,
		Toolsets: toolsets,
		BeforeModelCallbacks: []llmagent.BeforeModelCallback{
			func(ctx agent.CallbackContext, req *model.LLMRequest) (*model.LLMResponse, error) {
				// 只保留最近 10 条上下文信息，防止Token暴涨
				if len(req.Contents) > MaxContextLen {
					req.Contents = req.Contents[len(req.Contents)-MaxContextLen:]
				}
				return nil, nil
			},
		},
	})
	if err != nil {
		return nil, err
	}

	// Runner
	r, err := runner.New(runner.Config{
		AppName:        session.AppName(),
		Agent:          llmAgent,
		SessionService: session.Service(),
	})
	if err != nil {
		return nil, err
	}

	fmt.Println("chat success")

	return &Chat{
		runner:  r,
		session: session,
	}, nil
}
