package agent

import (
	"context"
	"database/sql"
	"fmt"
	"sync"

	"github.com/noble-gase/ne/sqlkit"
	"github.com/spf13/viper"
	"google.golang.org/adk/session"
	"google.golang.org/adk/session/database"
	"gorm.io/driver/mysql"
)

type Session struct {
	appname    string
	db         *sql.DB
	service    session.Service
	sidMap sync.Map
}

func (s *Session) AppName() string {
	return s.appname
}

func (s *Session) Service() session.Service {
	return s.service
}

func (s *Session) GetOrCreate(ctx context.Context, userId string) (string, error) {
	// 先从内存中获取
	if v, ok := s.sidMap.Load(userId); ok {
		return v.(string), nil
	}

	// 如果内存中没有，则从数据库中获取
	list, err := s.service.List(ctx, &session.ListRequest{
		AppName: s.appname,
		UserID:  userId,
	})
	if err != nil {
		return "", err
	}
	if len(list.Sessions) != 0 {
		sid := list.Sessions[0].ID()
		s.sidMap.Store(userId, sid)
		return sid, nil
	}

	// 如果数据库中没有，则创建一个新的会话
	session, err := s.service.Create(ctx, &session.CreateRequest{
		AppName: s.appname,
		UserID:  userId,
	})
	if err != nil {
		return "", err
	}
	s.sidMap.Store(userId, session.Session.ID())
	return session.Session.ID(), nil
}

func (s *Session) Close() error {
	fmt.Println("⌛️", "close session ...")
	if s.db != nil {
		return s.db.Close()
	}
	return nil
}

func NewSession(appname, cfgName string) (*Session, error) {
	var cfg sqlkit.Config
	if err := viper.UnmarshalKey(cfgName, &cfg); err != nil {
		return nil, err
	}

	db, err := sqlkit.NewDB(&cfg)
	if err != nil {
		return nil, err
	}

	svc, err := database.NewSessionService(mysql.New(mysql.Config{
		Conn: db,
	}))
	if err != nil {
		return nil, err
	}
	if err = database.AutoMigrate(svc); err != nil {
		return nil, err
	}

	return &Session{
		appname: appname,
		db:      db,
		service: svc,
	}, nil
}
