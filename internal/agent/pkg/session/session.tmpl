package session

import (
	"context"
	"database/sql"
	"fmt"
	"log/slog"
	"sync"
	"time"

	"github.com/noble-gase/ne/helper"
	"github.com/noble-gase/ne/sqlkit"
	"golang.org/x/sync/singleflight"
	"google.golang.org/adk/session"
	"google.golang.org/adk/session/database"
	"gorm.io/driver/mysql"
	"gorm.io/driver/postgres"
	"gorm.io/driver/sqlite"
	"gorm.io/gorm"
	"gorm.io/gorm/logger"
)

type Session struct {
	name    string
	db      *sql.DB
	service session.Service
	sidMap  sync.Map
	sf      singleflight.Group
}

func (s *Session) AppName() string {
	return s.name
}

func (s *Session) Service() session.Service {
	return s.service
}

func (s *Session) Close() error {
	fmt.Println("⌛️", "close session ...")
	if s.db != nil {
		return s.db.Close()
	}
	return nil
}

func (s *Session) GetOrCreate(ctx context.Context, userId string) (string, error) {
	// 先从内存中获取
	if v, ok := s.sidMap.Load(userId); ok {
		return v.(string), nil
	}

	// singleflight 合并单实例并发请求
	v, err, _ := s.sf.Do(userId, func() (any, error) {
		// double check
		if v, ok := s.sidMap.Load(userId); ok {
			return v.(string), nil
		}

		// 从数据库中获取
		sid, err := s.fetchSession(ctx, userId)
		if err != nil {
			return "", err
		}
		if len(sid) != 0 {
			s.sidMap.Store(userId, sid)
			return sid, nil
		}

		// 创建新的会话
		sid, err = s.createSession(ctx, userId)
		if err != nil {
			return "", err
		}
		s.sidMap.Store(userId, sid)
		return sid, nil
	})
	if err != nil {
		return "", err
	}
	return v.(string), nil
}

func (s *Session) fetchSession(ctx context.Context, userId string) (string, error) {
	list, err := s.service.List(ctx, &session.ListRequest{
		AppName: s.name,
		UserID:  userId,
	})
	if err != nil {
		return "", err
	}
	if len(list.Sessions) != 0 {
		return list.Sessions[0].ID(), nil
	}
	return "", nil
}

func (s *Session) createSession(ctx context.Context, userId string) (string, error) {
	resp, err := s.service.Create(ctx, &session.CreateRequest{
		AppName: s.name,
		UserID:  userId,
	})
	if err != nil {
		// 多实例竞争：另一个实例抢先创建，重试 List
		if helper.IsUniqueDuplicateError(err) {
			return s.fetchSession(ctx, userId)
		}
		return "", err
	}
	return resp.Session.ID(), nil
}

func New(appname string, cfg *sqlkit.Config) (*Session, error) {
	db, err := sqlkit.NewDB(cfg)
	if err != nil {
		return nil, err
	}

	var dialector gorm.Dialector
	switch cfg.Driver {
	case "mysql":
		dialector = mysql.New(mysql.Config{
			Conn: db,
		})
	case "pgx":
		dialector = postgres.New(postgres.Config{
			Conn: db,
		})
	case "sqlite3":
		dialector = sqlite.New(sqlite.Config{
			Conn: db,
		})
	default:
		return nil, fmt.Errorf("unsupported driver: %s", cfg.Driver)
	}

	svc, err := database.NewSessionService(dialector, &gorm.Config{
		Logger: logger.NewSlogLogger(slog.Default(), logger.Config{
			SlowThreshold:             time.Second,
			LogLevel:                  logger.Info,
			IgnoreRecordNotFoundError: true,
		}),
	})
	if err != nil {
		return nil, err
	}
	if err = database.AutoMigrate(svc); err != nil {
		return nil, err
	}

	return &Session{
		name:    appname,
		db:      db,
		service: svc,
	}, nil
}
